{
  "schemaVersion": "0.2",
  "agentId": "document-agent",
  "name": "Document Agent",
  "description": "Processes documents through declared skills.",
  "owner": {
    "id": "nene7ko",
    "displayName": "Nene7ko"
  },
  "version": "1.4.0",
  "protocol": {
    "type": "a2a",
    "version": "0.3.0",
    "transport": "JSONRPC",
    "endpoint": "https://agent.example.test/a2a"
  },
  "skills": [
    {
      "id": "document.publish",
      "name": "Publish document",
      "description": "Publishes a processed document.",
      "inputSchema": {
        "type": "object"
      },
      "outputSchema": {
        "type": "object"
      },
      "requiredPermissions": ["documents.write"]
    }
  ],
  "authentication": {
    "type": "none"
  },
  "permissions": [
    {
      "id": "documents.read",
      "description": "Read documents supplied for processing."
    }
  ],
  "limits": {
    "timeoutMs": 30000,
    "maxInputBytes": 1000000,
    "maxOutputBytes": 1000000,
    "streaming": true
  }
}
