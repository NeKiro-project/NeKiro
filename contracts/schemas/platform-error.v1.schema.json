{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.nekiro.dev/platform-error/v1",
  "title": "NeKiro Platform Error v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["code", "message"],
  "properties": {
    "code": {
      "enum": [
        "VALIDATION_ERROR",
        "UNAUTHENTICATED",
        "FORBIDDEN",
        "NOT_FOUND",
        "CONFLICT",
        "AGENT_NOT_INSTALLED",
        "AGENT_DISABLED",
        "CAPABILITY_NOT_ALLOWED",
        "ROUTE_NOT_FOUND",
        "A2A_PROTOCOL_ERROR",
        "AGENT_UNAVAILABLE",
        "AGENT_EXECUTION_FAILED",
        "DEPENDENCY_ERROR",
        "TIMEOUT",
        "CANCELED",
        "INTERNAL_ERROR"
      ]
    },
    "message": {
      "enum": [
        "The request is invalid.",
        "Authentication is required.",
        "The requested operation is not allowed.",
        "The requested resource was not found.",
        "The requested operation conflicts with current state.",
        "The Agent is not installed in this Workspace.",
        "The Agent version is disabled.",
        "The requested capability is not allowed.",
        "No route is available for the Agent.",
        "The Agent returned an invalid A2A response.",
        "The Agent is unavailable.",
        "The Agent failed to complete the invocation.",
        "A required platform dependency failed.",
        "The invocation timed out.",
        "The invocation was canceled.",
        "The platform could not complete the request."
      ]
    },
    "traceId": { "$ref": "https://schemas.nekiro.dev/common/v1#/$defs/traceId" }
  },
  "allOf": [
    { "if": { "properties": { "code": { "const": "VALIDATION_ERROR" } } }, "then": { "properties": { "message": { "const": "The request is invalid." } } } },
    { "if": { "properties": { "code": { "const": "UNAUTHENTICATED" } } }, "then": { "properties": { "message": { "const": "Authentication is required." } } } },
    { "if": { "properties": { "code": { "const": "FORBIDDEN" } } }, "then": { "properties": { "message": { "const": "The requested operation is not allowed." } } } },
    { "if": { "properties": { "code": { "const": "NOT_FOUND" } } }, "then": { "properties": { "message": { "const": "The requested resource was not found." } } } },
    { "if": { "properties": { "code": { "const": "CONFLICT" } } }, "then": { "properties": { "message": { "const": "The requested operation conflicts with current state." } } } },
    { "if": { "properties": { "code": { "const": "AGENT_NOT_INSTALLED" } } }, "then": { "properties": { "message": { "const": "The Agent is not installed in this Workspace." } } } },
    { "if": { "properties": { "code": { "const": "AGENT_DISABLED" } } }, "then": { "properties": { "message": { "const": "The Agent version is disabled." } } } },
    { "if": { "properties": { "code": { "const": "CAPABILITY_NOT_ALLOWED" } } }, "then": { "properties": { "message": { "const": "The requested capability is not allowed." } } } },
    { "if": { "properties": { "code": { "const": "ROUTE_NOT_FOUND" } } }, "then": { "properties": { "message": { "const": "No route is available for the Agent." } } } },
    { "if": { "properties": { "code": { "const": "A2A_PROTOCOL_ERROR" } } }, "then": { "properties": { "message": { "const": "The Agent returned an invalid A2A response." } } } },
    { "if": { "properties": { "code": { "const": "AGENT_UNAVAILABLE" } } }, "then": { "properties": { "message": { "const": "The Agent is unavailable." } } } },
    { "if": { "properties": { "code": { "const": "AGENT_EXECUTION_FAILED" } } }, "then": { "properties": { "message": { "const": "The Agent failed to complete the invocation." } } } },
    { "if": { "properties": { "code": { "const": "DEPENDENCY_ERROR" } } }, "then": { "properties": { "message": { "const": "A required platform dependency failed." } } } },
    { "if": { "properties": { "code": { "const": "TIMEOUT" } } }, "then": { "properties": { "message": { "const": "The invocation timed out." } } } },
    { "if": { "properties": { "code": { "const": "CANCELED" } } }, "then": { "properties": { "message": { "const": "The invocation was canceled." } } } },
    { "if": { "properties": { "code": { "const": "INTERNAL_ERROR" } } }, "then": { "properties": { "message": { "const": "The platform could not complete the request." } } } }
  ]
}
