{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.nekiro.dev/a2a-profile/v0.2",
  "title": "NeKiro A2A Profile Schema v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "protocolVersion",
    "sdk",
    "transport",
    "agentCardPath",
    "operations",
    "taskStates",
    "contextHeaders",
    "conformance"
  ],
  "properties": {
    "schemaVersion": { "const": "0.2" },
    "protocolVersion": { "const": "0.3.0" },
    "sdk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "version"],
      "properties": {
        "module": { "const": "github.com/a2aproject/a2a-go" },
        "version": { "const": "v0.3.15" }
      }
    },
    "transport": { "const": "JSONRPC" },
    "agentCardPath": { "const": "/.well-known/agent-card.json" },
    "operations": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/operation" },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": ["method", "clientMethod", "serverMethod", "interaction", "requestType", "acceptedResultKinds"],
            "properties": {
              "method": { "const": "message/send" },
              "clientMethod": { "const": "SendMessage" },
              "serverMethod": { "const": "OnSendMessage" },
              "interaction": { "const": "request-response" },
              "requestType": { "const": "*a2a.MessageSendParams" },
              "acceptedResultKinds": { "const": ["message", "task"] }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "required": ["method", "clientMethod", "serverMethod", "interaction", "requestType", "acceptedEventKinds"],
            "properties": {
              "method": { "const": "message/stream" },
              "clientMethod": { "const": "SendStreamingMessage" },
              "serverMethod": { "const": "OnSendMessageStream" },
              "interaction": { "const": "server-stream" },
              "requestType": { "const": "*a2a.MessageSendParams" },
              "acceptedEventKinds": { "const": ["message", "task", "status-update", "artifact-update"] }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "required": ["method", "clientMethod", "serverMethod", "interaction", "requestType", "acceptedResultKinds", "expectedErrors"],
            "properties": {
              "method": { "const": "tasks/get" },
              "clientMethod": { "const": "GetTask" },
              "serverMethod": { "const": "OnGetTask" },
              "interaction": { "const": "request-response" },
              "requestType": { "const": "*a2a.TaskQueryParams" },
              "acceptedResultKinds": { "const": ["task"] },
              "expectedErrors": { "const": ["task-not-found"] }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "required": ["method", "clientMethod", "serverMethod", "interaction", "requestType", "acceptedResultKinds", "expectedErrors"],
            "properties": {
              "method": { "const": "tasks/cancel" },
              "clientMethod": { "const": "CancelTask" },
              "serverMethod": { "const": "OnCancelTask" },
              "interaction": { "const": "request-response" },
              "requestType": { "const": "*a2a.TaskIDParams" },
              "acceptedResultKinds": { "const": ["task"] },
              "expectedErrors": { "const": ["task-not-found", "task-not-cancelable"] }
            }
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "taskStates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transient", "terminal", "unsupported", "unspecified"],
      "properties": {
        "transient": {
          "const": [
            { "state": "submitted", "invocationStatus": "running" },
            { "state": "working", "invocationStatus": "running" }
          ]
        },
        "terminal": {
          "const": [
            { "state": "completed", "invocationStatus": "succeeded" },
            { "state": "failed", "invocationStatus": "failed", "errorCode": "AGENT_EXECUTION_FAILED" },
            { "state": "canceled", "invocationStatus": "canceled", "errorCode": "CANCELED" },
            { "state": "rejected", "invocationStatus": "failed", "errorCode": "AGENT_EXECUTION_FAILED" }
          ]
        },
        "unsupported": {
          "const": [
            { "state": "auth-required", "invocationStatus": "failed", "errorCode": "A2A_PROTOCOL_ERROR" },
            { "state": "input-required", "invocationStatus": "failed", "errorCode": "A2A_PROTOCOL_ERROR" },
            { "state": "unknown", "invocationStatus": "failed", "errorCode": "A2A_PROTOCOL_ERROR" }
          ]
        },
        "unspecified": {
          "const": { "state": "", "invocationStatus": "failed", "errorCode": "A2A_PROTOCOL_ERROR" }
        }
      }
    },
    "contextHeaders": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceId", "invocationId", "rootTaskId", "parentInvocationId", "workspaceId"],
      "properties": {
        "traceId": { "const": "x-nek-trace-id" },
        "invocationId": { "const": "x-nek-invocation-id" },
        "rootTaskId": { "const": "x-nek-root-task-id" },
        "parentInvocationId": { "const": "x-nek-parent-invocation-id" },
        "workspaceId": { "const": "x-nek-workspace-id" }
      }
    },
    "conformance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest", "fixtureAuthority", "jsonrpcVersion", "sseMediaType"],
      "properties": {
        "manifest": { "const": "conformance/manifest.json" },
        "fixtureAuthority": { "const": "hand-authored" },
        "jsonrpcVersion": { "const": "2.0" },
        "sseMediaType": { "const": "text/event-stream" }
      }
    }
  },
  "$defs": {
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "clientMethod", "serverMethod", "interaction", "requestType"],
      "properties": {
        "method": { "enum": ["message/send", "message/stream", "tasks/get", "tasks/cancel"] },
        "clientMethod": { "enum": ["SendMessage", "SendStreamingMessage", "GetTask", "CancelTask"] },
        "serverMethod": { "enum": ["OnSendMessage", "OnSendMessageStream", "OnGetTask", "OnCancelTask"] },
        "interaction": { "enum": ["request-response", "server-stream"] },
        "requestType": {
          "enum": ["*a2a.MessageSendParams", "*a2a.TaskQueryParams", "*a2a.TaskIDParams"]
        },
        "acceptedResultKinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["message", "task"] }
        },
        "acceptedEventKinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["message", "task", "status-update", "artifact-update"] }
        },
        "expectedErrors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["task-not-found", "task-not-cancelable"] }
        }
      }
    }
  }
}
